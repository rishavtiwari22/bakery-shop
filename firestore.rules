rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null && (
        request.auth.token.email == 'aamilmalick94@gmail.com' || 
        request.auth.token.email == 'rishav@navgurukul.org' || 
        userDoc.role == 'admin' || 
        userDoc.role == 'sub-admin'
      );
    }

    // Items: public read, only admin can write (except stock updates during checkout)
    match /items/{itemId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.auth != null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQty', 'isOutOfStock'])
      );
    }
    
    // Orders: authenticated customers can create; admin can read/update all
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        (resource.data.customerId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Users: own profile only, admin can read/write all
    match /users/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
    }

    // Reviews: public read, authenticated can create
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Settings: public read, admin write
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Payment Intents: customer can create/update their own; admin can manage all
    match /payment_intents/{intentId} {
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.customerId == request.auth.uid || isAdmin());
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
